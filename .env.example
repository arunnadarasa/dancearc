PORT=8787

# Payee for Arc native USDC — must be a valid EVM address (0x + 40 hex). UUID-style values are ignored; server falls back to a demo address.
ARC_RECIPIENT=0xYourAddress

# Per-call price in USDC (≤ 0.01 for hackathon)
PER_ACTION_USDC=0.001

# Optional — x402 verify waits for tx receipt on Arc RPC (avoids race after wallet returns hash)
# ARC_TX_RECEIPT_TIMEOUT_MS=120000
# ARC_TX_RECEIPT_POLL_MS=2000

# --- Circle Console keys (Testnet) — https://console.circle.com/api-keys/create ---
# API Key — authenticate backend calls to Circle (Gateway x402, Wallets, Contracts APIs).
# CIRCLE_API_KEY=
# CIRCLE_API_BASE_URL=https://api.circle.com
#
# Entity Secret — Developer-Controlled Wallets (server only; never expose to Vite).
# Generate + register locally: npm run circle:entity-secret:generate  →  add hex to .env  →  npm run circle:entity-secret:register
# https://developers.circle.com/wallets/dev-controlled/entity-secret-management
# CIRCLE_ENTITY_SECRET=
# Optional — directory for recovery .dat files (default: .circle-recovery/)
# CIRCLE_RECOVERY_DIR=
# Optional — reuse an existing wallet set id instead of creating one each time
# CIRCLE_DCW_WALLET_SET_ID=
# Optional — require this value in X-DanceArc-Dcw-Secret or Authorization: Bearer for POST /api/dev-wallets/create
# DEV_WALLET_SECRET=
#
# Kit Key — App Kit / Bridge Kit / Stablecoin Kit features (network-agnostic in console).
# CIRCLE_KIT_KEY=
#
# Client Key — Modular Wallets (browser). Used with @circle-fin/modular-wallets-core (Test Modular API button).
# VITE_CIRCLE_CLIENT_KEY=
# Optional — defaults to https://modular-sdk.circle.com (staging: https://modular-sdk-staging.circle.com)
# VITE_CIRCLE_MODULAR_CLIENT_URL=
# On localhost, direct browser calls can fail CORS; the app uses Express POST /api/circle-modular unless set.
# If you see HTTP 403 Lockout: proxy strips :5173 from Origin by default. Set CIRCLE_MODULAR_PRESERVE_ORIGIN=1 if Console allowlists http://localhost:5173. Add 127.0.0.1 in Console if you use that host.
# VITE_CIRCLE_MODULAR_DIRECT=1
# Server-only — where /api/circle-modular forwards (staging: https://modular-sdk-staging.circle.com)
# CIRCLE_MODULAR_SDK_URL=https://modular-sdk.circle.com

# Burst script only — test keys; never use mainnet secrets
# ARC_BURST_PRIVATE_KEY=0x...
# BURST_COUNT=55
# BURST_AMOUNT_USDC=0.0005
